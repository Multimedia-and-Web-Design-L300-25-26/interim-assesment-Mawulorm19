# ─────────────────────────────────────────────
#  Coinbase Backend — Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:   mongodb://localhost:27017/coinbase_db
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/coinbase_db
#MONGO_URI=mongodb://localhost:27017/coinbase_db

# JWT
# Use a long, random string (e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173
